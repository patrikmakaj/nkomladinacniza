---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { url } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
  /** Path do OG slike (relativan, npr. "/images/og-image.png"). Default je grb na plavoj pozadini, 1200×630. */
  image?: string;
  /** og:type — default "website", za novosti može biti "article" */
  ogType?: "website" | "article";
  /** Indeksiranje — default true. Postavi false za debug/admin stranice. */
  noIndex?: boolean;
}

const {
  title = "NK Omladinac Niza",
  description = "Službena web stranica nogometnog kluba NK Omladinac Niza iz mjesta Niza, Općina Koška. Tablica, raspored, igrači, novosti.",
  image = "/images/og-image.png",
  ogType = "website",
  noIndex = false,
} = Astro.props;

const fullTitle =
  title === "NK Omladinac Niza" ? title : `${title} | NK Omladinac Niza`;

// Apsolutne URL-ove iz Astro context-a
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(url(image), Astro.site).toString();
---

<!doctype html>
<html lang="hr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="NK Omladinac Niza" />
    <meta property="og:locale" content="hr_HR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Theme color (mobile chrome bar) -->
    <meta name="theme-color" content="#0f2c6e" />

    <title>{fullTitle}</title>

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
