---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";

// Placeholder slike - generiramo gradijente kao SVG dok ne dodamo prave fotke
const photos = Array.from({ length: 18 }, (_, i) => {
  const hues = [0, 15, 30, 220, 240, 260];
  const hue = hues[i % hues.length];
  const aspect = i % 4 === 0 ? "tall" : i % 5 === 0 ? "wide" : "square";
  return {
    id: i + 1,
    title: `Galerija slika ${i + 1}`,
    placeholder: `linear-gradient(${135 + i * 10}deg, hsl(${hue}, 60%, 25%), hsl(${hue}, 70%, 45%))`,
    aspect,
  };
});

const aspectClass = {
  square: "aspect-square",
  tall: "aspect-[3/4]",
  wide: "aspect-[4/3]",
};
---

<BaseLayout title="Galerija" description="Fotografije s utakmica i događaja NK Omladinac Niza.">
  <Hero
    title="Galerija"
    subtitle="Trenuci s naših utakmica, treninga i klupskih događaja"
    height="md"
  />

  <section class="container-narrow mt-12">
    <div
      id="gallery-grid"
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4"
    >
      {
        photos.map((p) => (
          <button
            type="button"
            data-photo-id={p.id}
            class={`gallery-item group relative ${aspectClass[p.aspect as keyof typeof aspectClass]} overflow-hidden rounded-lg cursor-pointer focus:outline-none focus:ring-2 focus:ring-club-primary`}
            style={`background: ${p.placeholder};`}
            aria-label={p.title}
          >
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors flex items-center justify-center">
              <svg
                class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m-3-3h6" />
              </svg>
            </div>
          </button>
        ))
      }
    </div>

    <p class="text-center text-sm text-club-muted mt-8">
      Galerija će se popuniti pravim fotografijama uskoro.
    </p>
  </section>

  <!-- Lightbox dialog -->
  <dialog
    id="lightbox"
    class="m-0 p-0 max-w-none w-full h-full bg-black/95 backdrop:bg-black/80"
  >
    <div class="relative w-full h-full flex items-center justify-center">
      <button
        id="lightbox-close"
        class="absolute top-4 right-4 z-10 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center"
        aria-label="Zatvori"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <button
        id="lightbox-prev"
        class="absolute left-4 z-10 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center"
        aria-label="Prethodna"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="lightbox-next"
        class="absolute right-4 z-10 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center"
        aria-label="Sljedeća"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
      <div
        id="lightbox-content"
        class="w-[80vw] h-[80vh] max-w-4xl rounded-lg shadow-2xl"
      ></div>
      <p id="lightbox-caption" class="absolute bottom-6 text-white/80 text-sm"></p>
    </div>
  </dialog>
</BaseLayout>

<script>
  type PhotoData = { id: number; bg: string; title: string };

  const items = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".gallery-item"),
  );
  const photos: PhotoData[] = items.map((el) => ({
    id: Number(el.dataset.photoId),
    bg: el.style.background,
    title: el.getAttribute("aria-label") || "",
  }));

  const dialog = document.getElementById("lightbox") as HTMLDialogElement;
  const content = document.getElementById("lightbox-content") as HTMLElement;
  const caption = document.getElementById("lightbox-caption") as HTMLElement;
  const closeBtn = document.getElementById("lightbox-close");
  const prevBtn = document.getElementById("lightbox-prev");
  const nextBtn = document.getElementById("lightbox-next");

  let currentIdx = 0;

  function show(idx: number) {
    currentIdx = (idx + photos.length) % photos.length;
    const p = photos[currentIdx];
    content.style.background = p.bg;
    caption.textContent = p.title;
  }

  items.forEach((el, idx) => {
    el.addEventListener("click", () => {
      show(idx);
      dialog.showModal();
    });
  });

  closeBtn?.addEventListener("click", () => dialog.close());
  prevBtn?.addEventListener("click", () => show(currentIdx - 1));
  nextBtn?.addEventListener("click", () => show(currentIdx + 1));

  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

  document.addEventListener("keydown", (e) => {
    if (!dialog.open) return;
    if (e.key === "ArrowLeft") show(currentIdx - 1);
    if (e.key === "ArrowRight") show(currentIdx + 1);
  });
</script>
