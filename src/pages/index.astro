---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import NextMatchCard from "../components/NextMatchCard.astro";
import MatchDayHero from "../components/MatchDayHero.astro";
import LeagueTable from "../components/LeagueTable.astro";
import RecentResults from "../components/RecentResults.astro";
import LatestPostBlock from "../components/LatestPostBlock.astro";
import SchemaSportsTeam from "../components/SchemaSportsTeam.astro";
import hns from "../data/hns.json";
import { url } from "../lib/url";

// Detekcija "match day" — usporedba s današnjim datumom u Europe/Zagreb
const nextMatch = hns.nextMatch;
const todayInZagreb = new Intl.DateTimeFormat("en-CA", {
  timeZone: "Europe/Zagreb",
}).format(new Date()); // npr. "2026-04-28"
const matchDate = nextMatch?.iso?.slice(0, 10) ?? null;
const isMatchDay = !!nextMatch && matchDate === todayInZagreb;
---

<BaseLayout
  title="NK Omladinac Niza"
  description="Službena web stranica nogometnog kluba NK Omladinac Niza - rezultati, tablica, momčad i sve novosti iz kluba."
>
  <SchemaSportsTeam slot="head" />

  {/* Match-day hero — prikazuje se samo na dan utakmice */}
  {isMatchDay && nextMatch && <MatchDayHero match={nextMatch} />}

  {/* Slavljenički banner — naslov prvaka 2025/26 */}
  <aside class="bg-gradient-to-r from-club-accent via-yellow-300 to-club-accent text-club-primary-deep border-b-2 border-club-primary-deep/20 shadow-md">
    <div class="container-narrow py-3 md:py-4 flex items-center justify-center gap-3 md:gap-5 text-center">
      <span class="text-3xl md:text-4xl flex-shrink-0" aria-hidden="true">🏆</span>
      <div>
        <p class="font-display font-bold text-sm md:text-lg uppercase tracking-wider leading-tight">
          Prvaci Lige NS Našice · Sezona 2025/26
        </p>
        <p class="text-xs md:text-sm text-club-primary-deep/85 mt-0.5">
          Naslov osiguran <strong>4 kola prije kraja</strong> — povratak u 2. ŽNL!
        </p>
      </div>
      <span class="text-3xl md:text-4xl flex-shrink-0" aria-hidden="true">🏆</span>
    </div>
  </aside>

  <Hero
    title="Omladinac Niza"
    subtitle="Tradicija, strast i nogomet u našoj zajednici"
  >
    <div class="flex flex-wrap gap-3 mt-8">
      <a href={url("/momcad")} class="btn-primary">Upoznaj momčad</a>
      <a href={url("/klub")} class="btn-outline">O klubu</a>
    </div>
  </Hero>

  {/* Sljedeća utakmica - flotira preko hero ruba.
       Skrivena na match day jer iste informacije su u MatchDayHero banneru iznad. */}
  {!isMatchDay && (
    <section class="container-narrow -mt-20 relative z-10">
      <NextMatchCard />
    </section>
  )}

  <!-- Najnovija objava s Facebooka (pinned) -->
  <LatestPostBlock />

  <!-- Tablica (cijela) -->
  <section class="container-narrow mt-16">
    <h2 class="text-2xl mb-4">Tablica</h2>
    <LeagueTable />
  </section>

  <!-- Zadnji rezultati ispod tablice u 2 stupca -->
  <section class="container-narrow mt-12">
    <h2 class="text-2xl mb-4">Zadnji rezultati</h2>
    <RecentResults limit={6} grid={true} />
  </section>

  <!-- O klubu CTA -->
  <section class="container-narrow mt-20">
    <div
      class="bg-club-secondary text-white rounded-lg p-8 md:p-12 grid md:grid-cols-2 gap-8 items-center overflow-hidden relative"
    >
      <div
        class="absolute -right-20 -top-20 w-64 h-64 rounded-full bg-club-primary opacity-20"
      >
      </div>
      <div class="relative">
        <h2 class="text-3xl md:text-4xl mb-4">O klubu</h2>
        <p class="text-white/80 leading-relaxed mb-6">
          NK Omladinac Niza je nogometni klub iz mjesta Niza u Općini Koška, osnovan
          <strong class="text-club-accent">davne 1963. godine</strong>. Više od šest
          desetljeća okupljamo generacije mladih oko ljubavi prema nogometu — od mladih
          nada koje su prošle kroz klub do seniorske momčadi koja danas brani naše boje.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={url("/klub")} class="btn-primary">Više o klubu</a>
          <a href={url("/povijest")} class="btn-outline">Povijest</a>
        </div>
      </div>
      <div class="relative grid grid-cols-2 gap-4">
        <div class="bg-white/5 backdrop-blur rounded-lg p-6 text-center">
          <p class="font-display text-4xl font-bold text-club-accent">63</p>
          <p class="text-sm text-white/70 mt-1">godine tradicije</p>
        </div>
        <div class="bg-white/5 backdrop-blur rounded-lg p-6 text-center">
          <p class="font-display text-4xl font-bold text-club-accent">100+</p>
          <p class="text-sm text-white/70 mt-1">djece kroz klub</p>
        </div>
        <div class="bg-white/5 backdrop-blur rounded-lg p-6 text-center">
          <p class="font-display text-4xl font-bold text-club-accent">6</p>
          <p class="text-sm text-white/70 mt-1">naslova prvaka</p>
        </div>
        <div class="bg-white/5 backdrop-blur rounded-lg p-6 text-center">
          <p class="font-display text-4xl font-bold text-club-accent">100</p>
          <p class="text-sm text-white/70 mt-1">sjedalica tribina</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
