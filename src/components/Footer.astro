---
import Logo from "./Logo.astro";
import { url } from "../lib/url";

const year = new Date().getFullYear();
---

<footer class="bg-club-primary-deep text-white/80 mt-16 border-t-4 border-club-accent">
  <div class="container-narrow py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <Logo size={48} />
        <span class="font-display font-bold uppercase tracking-wider text-white">
          NK Omladinac Niza
        </span>
      </div>
      <p class="text-sm leading-relaxed">
        Lokalni nogometni klub s dugom tradicijom okupljanja mladih i ljubitelja nogometa
        u našoj zajednici.
      </p>
    </div>

    <div>
      <h4 class="text-white text-sm mb-4">Navigacija</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={url("/novosti")} class="hover:text-club-accent">Novosti</a></li>
        <li><a href={url("/raspored")} class="hover:text-club-accent">Raspored</a></li>
        <li><a href={url("/momcad")} class="hover:text-club-accent">Momčad</a></li>
        <li><a href={url("/mladje-kategorije")} class="hover:text-club-accent">Mlađe kategorije</a></li>
        <li><a href={url("/galerija")} class="hover:text-club-accent">Galerija</a></li>
        <li><a href={url("/klub")} class="hover:text-club-accent">Klub</a></li>
        <li><a href={url("/sponzori")} class="hover:text-club-accent">Sponzori</a></li>
        <li><a href={url("/povijest")} class="hover:text-club-accent">Povijest</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white text-sm mb-4">Kontakt</h4>
      <ul class="space-y-2 text-sm">
        <li>NK Omladinac Niza</li>
        <li>Kolodvorska 50a, 31224 Koška</li>
        <li>
          <a href="mailto:omladinacniza@gmail.com" class="hover:text-club-accent">
            omladinacniza@gmail.com
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/omladinacniza"
            target="_blank"
            rel="noopener"
            class="hover:text-club-accent"
          >
            facebook.com/omladinacniza
          </a>
        </li>
      </ul>
      <div class="flex gap-3 mt-4">
        <a
          href="https://www.facebook.com/omladinacniza"
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-club-accent flex items-center justify-center transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22.675 0H1.325C.593 0 0 .593 0 1.325v21.351C0 23.407.593 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.323-.593 1.323-1.325V1.325C24 .593 23.407 0 22.675 0z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/nizaomladinac"
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-club-accent flex items-center justify-center transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/@nkomladinacniza"
          target="_blank"
          rel="noopener"
          aria-label="YouTube"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-club-accent flex items-center justify-center transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
        <a
          href="https://omladinacniza.blogspot.com/"
          target="_blank"
          rel="noopener"
          aria-label="Blog"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-club-accent flex items-center justify-center transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-narrow py-4 text-xs text-white/50 flex flex-col sm:flex-row justify-between gap-2">
      <p>&copy; {year} NK Omladinac Niza. Sva prava pridržana.</p>
      <p>Izrađeno s ljubavlju za klub.</p>
    </div>
  </div>
</footer>
