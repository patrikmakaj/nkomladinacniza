---
import Logo from "./Logo.astro";
import hns from "../data/hns.json";

const nextMatch = hns.nextMatch;

let dateLabel = "";
let dayLabel = "";
let timeLabel = "";
if (nextMatch?.iso) {
  const dateObj = new Date(nextMatch.iso);
  dateLabel = dateObj.toLocaleDateString("hr-HR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
  dayLabel = dateObj.toLocaleDateString("hr-HR", { weekday: "long" });
  timeLabel = nextMatch.time || "";
}

const venue = nextMatch?.isHome
  ? "Grbavica, Niza"
  : `Gosti · ${nextMatch?.away?.name ?? ""}`;
---

{
  nextMatch ? (
    <article class="bg-white shadow-2xl rounded-lg overflow-hidden border border-club-border">
      <div class="bg-gradient-to-r from-club-primary-deep to-club-primary text-white px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="font-display uppercase tracking-wider text-sm font-bold">
            Sljedeća utakmica
          </span>
        </div>
        <span class="text-xs font-display uppercase tracking-widest opacity-90">
          {nextMatch.competition}
        </span>
      </div>

      <div class="p-6 md:p-8">
        <div class="grid grid-cols-3 items-center gap-4">
          {/* Domaći */}
          <div class="text-center">
            <div class="w-20 h-20 md:w-24 md:h-24 mx-auto mb-3 flex items-center justify-center">
              {nextMatch.home.id === 134 ? (
                <Logo size={96} />
              ) : nextMatch.home.logo ? (
                <img
                  src={nextMatch.home.logo}
                  alt={`${nextMatch.home.name} grb`}
                  width="96"
                  height="96"
                  class="object-contain"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full rounded-full bg-club-light flex items-center justify-center text-club-primary-deep font-display font-bold border-2 border-club-border">
                  ?
                </div>
              )}
            </div>
            <p class="font-display font-bold uppercase text-sm md:text-base leading-tight">
              {nextMatch.home.name}
            </p>
          </div>

          {/* Vrijeme */}
          <div class="text-center">
            <p class="text-xs uppercase tracking-widest text-club-muted mb-1">
              {dayLabel}
            </p>
            <p class="font-display font-bold text-2xl md:text-3xl text-club-primary-deep">
              {timeLabel}
            </p>
            <p class="text-sm text-club-muted mt-1">{dateLabel}</p>
          </div>

          {/* Gosti */}
          <div class="text-center">
            <div class="w-20 h-20 md:w-24 md:h-24 mx-auto mb-3 flex items-center justify-center">
              {nextMatch.away.id === 134 ? (
                <Logo size={96} />
              ) : nextMatch.away.logo ? (
                <img
                  src={nextMatch.away.logo}
                  alt={`${nextMatch.away.name} grb`}
                  width="96"
                  height="96"
                  class="object-contain"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full rounded-full bg-club-light flex items-center justify-center text-club-primary-deep font-display font-bold border-2 border-club-border">
                  ?
                </div>
              )}
            </div>
            <p class="font-display font-bold uppercase text-sm md:text-base leading-tight">
              {nextMatch.away.name}
            </p>
          </div>
        </div>

        <div class="mt-6 pt-4 border-t border-club-border flex items-center justify-center gap-2 text-sm text-club-muted">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>{venue}</span>
        </div>
      </div>
    </article>
  ) : (
    <article class="bg-white shadow-xl rounded-lg overflow-hidden border border-club-border p-8 text-center">
      <p class="text-club-muted">Nema rasporeda za sljedeću utakmicu.</p>
    </article>
  )
}
