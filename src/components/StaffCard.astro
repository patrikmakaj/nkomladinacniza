---
interface Props {
  name: string;
  role: string;
  photo?: string;
  bio?: string;
}

const { name, role, photo, bio } = Astro.props;

const initials = name
  .split(" ")
  .map((n) => n[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<article
  class="bg-white border border-club-border border-l-4 border-l-club-primary rounded-lg overflow-hidden flex flex-col sm:flex-row"
>
  <div class="flex-shrink-0 w-full sm:w-40 md:w-44 aspect-square sm:aspect-auto bg-gradient-to-br from-club-primary-deep to-club-primary/40 flex items-center justify-center overflow-hidden">
    {photo ? (
      <img
        src={photo}
        alt={name}
        data-staff-fallback={initials}
        class="w-full h-full object-cover object-top"
        loading="lazy"
      />
    ) : (
      <span class="font-display text-6xl text-white/40 font-bold">{initials}</span>
    )}
  </div>
  <div class="p-5 md:p-6 flex flex-col justify-center">
    <span class="inline-flex items-center self-start px-2 py-0.5 mb-2 text-[11px] font-display uppercase tracking-widest font-bold text-club-primary-deep bg-club-accent rounded-sm">
      {role}
    </span>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-club-primary-deep leading-tight">
      {name}
    </h2>
    {bio && <p class="text-sm text-club-secondary/80 mt-2">{bio}</p>}
  </div>
</article>

<script>
  function swapToFallback(img: HTMLImageElement) {
    const initials = img.dataset.staffFallback || "";
    const span = document.createElement("span");
    span.className = "font-display text-6xl text-white/40 font-bold";
    span.textContent = initials;
    img.replaceWith(span);
  }
  document.querySelectorAll<HTMLImageElement>("img[data-staff-fallback]").forEach((img) => {
    if (img.complete && img.naturalWidth === 0) {
      swapToFallback(img);
    } else {
      img.addEventListener("error", () => swapToFallback(img));
    }
  });
</script>
