---
import { url } from "../lib/url";

interface Props {
  size?: number;
  class?: string;
}

const { size = 40, class: className = "" } = Astro.props;
---

<img
  src={url("/images/logo.svg")}
  alt="NK Omladinac Niza grb"
  width={size}
  height={size}
  class={`object-contain ${className}`}
  loading="eager"
/>
