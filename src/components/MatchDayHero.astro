---
/**
 * Match-day hero banner — prikazuje se samo na dan utakmice.
 *
 * Server-side renderira kad je `match.iso` datum jednak današnjem u
 * Europe/Zagreb timezone-u. Client-side ticker odbrojava do prvog
 * zvižduka, prelazi u "U tijeku" stanje nakon kickoffa, i auto-hide-a
 * cijeli banner ~2.5h nakon kickoffa.
 *
 * Napomena: za odbrojavanje koristimo `new Date(iso)` što ISO string
 * bez TZ-a parsira kao lokalno vrijeme. Posjetitelji izvan Europe/Zagreb
 * dobit će countdown pomaknut za vrijednost svoje TZ razlike — to je
 * prihvatljivo jer je stranica primarno za lokalnu publiku.
 */
import Logo from "./Logo.astro";

interface Props {
  match: {
    iso: string;
    time: string;
    competition: string;
    isHome: boolean;
    home: { id: number; name: string; logo: string | null };
    away: { id: number; name: string; logo: string | null };
  };
}

const { match } = Astro.props;

// Vrijeme prikazujemo direktno iz ISO stringa (HH:MM dio) — izbjegava TZ trikove
const kickoffTime = match.iso.slice(11, 16);

const venue = match.isHome
  ? "Grbavica · Niza"
  : `Gosti · ${match.home.name}`;

// Skratimo dugačke nazive klubova (npr. "NK Omladinac Niza" → "Omladinac")
function shortName(name: string): string {
  return name.replace(/^NK\s+/, "");
}
---

<aside
  id="match-day-hero"
  data-kickoff-iso={match.iso}
  class="match-day-hero relative bg-gradient-to-br from-club-primary-deep via-club-secondary to-club-primary text-white overflow-hidden border-b-4 border-club-accent shadow-2xl"
>
  {/* Decorativni grb watermark */}
  <div class="absolute -right-20 top-1/2 -translate-y-1/2 opacity-10 pointer-events-none">
    <Logo size={400} />
  </div>

  {/* Akcent svjetlo */}
  <div
    class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full blur-3xl opacity-25 pointer-events-none"
    style="background: radial-gradient(circle, #d4b659 0%, transparent 70%);"
  >
  </div>

  <div class="container-narrow relative py-8 md:py-12">
    {/* Top — DANAS badge + natjecanje */}
    <div class="flex justify-center items-center gap-3 mb-6 flex-wrap">
      <span
        id="match-status-badge"
        class="inline-flex items-center gap-2 px-3 py-1 bg-red-600 rounded-full text-xs font-display uppercase tracking-widest font-bold shadow-lg"
      >
        <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
        <span id="match-status-label">Danas</span>
      </span>
      <span class="text-xs uppercase tracking-wider text-white/70">
        {match.competition}
      </span>
    </div>

    {/* Domaći vs Gosti */}
    <div class="grid grid-cols-3 items-center gap-2 md:gap-6 mb-8">
      {/* Domaći */}
      <div class="text-center">
        <div class="w-16 h-16 md:w-24 md:h-24 mx-auto mb-2 md:mb-3 flex items-center justify-center">
          {match.home.id === 134 ? (
            <Logo size={96} />
          ) : match.home.logo ? (
            <img
              src={match.home.logo}
              alt={`${match.home.name} grb`}
              width="96"
              height="96"
              class="object-contain w-full h-full"
              loading="eager"
            />
          ) : (
            <div class="w-full h-full rounded-full bg-white/10 flex items-center justify-center text-white/40">?</div>
          )}
        </div>
        <p class="font-display font-bold uppercase text-sm md:text-lg leading-tight">
          {shortName(match.home.name)}
        </p>
      </div>

      {/* Vrijeme */}
      <div class="text-center">
        <p class="text-xs uppercase tracking-widest text-club-accent font-display font-bold mb-1">
          Prvi zvižduk
        </p>
        <p class="font-display font-bold text-4xl md:text-6xl text-club-accent leading-none">
          {kickoffTime}
        </p>
      </div>

      {/* Gosti */}
      <div class="text-center">
        <div class="w-16 h-16 md:w-24 md:h-24 mx-auto mb-2 md:mb-3 flex items-center justify-center">
          {match.away.id === 134 ? (
            <Logo size={96} />
          ) : match.away.logo ? (
            <img
              src={match.away.logo}
              alt={`${match.away.name} grb`}
              width="96"
              height="96"
              class="object-contain w-full h-full"
              loading="eager"
            />
          ) : (
            <div class="w-full h-full rounded-full bg-white/10 flex items-center justify-center text-white/40">?</div>
          )}
        </div>
        <p class="font-display font-bold uppercase text-sm md:text-lg leading-tight">
          {shortName(match.away.name)}
        </p>
      </div>
    </div>

    {/* Countdown ili "U tijeku" */}
    <div id="match-countdown-wrap" class="text-center">
      <p
        id="match-countdown-label"
        class="text-xs md:text-sm text-white/80 uppercase tracking-widest mb-3"
      >
        Do prvog zvižduka
      </p>
      <div
        id="match-countdown"
        class="inline-flex items-end gap-3 md:gap-6 font-display font-bold"
      >
        <div class="text-center">
          <span id="cd-h" class="block text-3xl md:text-5xl tabular-nums leading-none">--</span>
          <span class="text-[10px] md:text-xs uppercase tracking-widest text-white/60 mt-1 inline-block">sati</span>
        </div>
        <span class="text-3xl md:text-5xl text-white/40 leading-none">:</span>
        <div class="text-center">
          <span id="cd-m" class="block text-3xl md:text-5xl tabular-nums leading-none">--</span>
          <span class="text-[10px] md:text-xs uppercase tracking-widest text-white/60 mt-1 inline-block">min</span>
        </div>
        <span class="text-3xl md:text-5xl text-white/40 leading-none">:</span>
        <div class="text-center">
          <span id="cd-s" class="block text-3xl md:text-5xl tabular-nums leading-none">--</span>
          <span class="text-[10px] md:text-xs uppercase tracking-widest text-white/60 mt-1 inline-block">sek</span>
        </div>
      </div>
    </div>

    {/* Venue */}
    <p class="text-center text-sm text-white/80 mt-6 flex items-center justify-center gap-1.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span>{venue}</span>
    </p>
  </div>
</aside>

<script>
  const banner = document.getElementById("match-day-hero");
  if (banner) {
    const iso = banner.dataset.kickoffIso;
    if (iso) {
      const kickoffMs = new Date(iso).getTime();
      const HIDE_AFTER_MS = 2.5 * 60 * 60 * 1000; // 2.5h nakon kickoffa
      const HALFTIME_MS = 45 * 60 * 1000;
      const FULLTIME_MS = 105 * 60 * 1000; // 90 + 15 pauza, gruba procjena

      const hEl = document.getElementById("cd-h");
      const mEl = document.getElementById("cd-m");
      const sEl = document.getElementById("cd-s");
      const labelEl = document.getElementById("match-countdown-label");
      const countdownEl = document.getElementById("match-countdown");
      const statusLabel = document.getElementById("match-status-label");
      const statusBadge = document.getElementById("match-status-badge");

      function pad(n: number): string {
        return String(n).padStart(2, "0");
      }

      function tick() {
        const now = Date.now();
        const diff = kickoffMs - now;

        if (now > kickoffMs + HIDE_AFTER_MS) {
          // Sakrij banner — utakmica je gotova davno
          banner!.style.display = "none";
          return;
        }

        if (diff > 0) {
          // PRE-MATCH: countdown
          const totalSec = Math.floor(diff / 1000);
          const h = Math.floor(totalSec / 3600);
          const m = Math.floor((totalSec % 3600) / 60);
          const s = totalSec % 60;
          if (hEl) hEl.textContent = pad(h);
          if (mEl) mEl.textContent = pad(m);
          if (sEl) sEl.textContent = pad(s);
          if (labelEl) labelEl.textContent = "Do prvog zvižduka";
          if (statusLabel) statusLabel.textContent = "Danas";
          return;
        }

        // POST-KICKOFF: utakmica u tijeku
        const elapsedMs = now - kickoffMs;
        const elapsedMin = Math.floor(elapsedMs / 60000);

        // Sakri countdown brojeve, prikaži stanje
        if (countdownEl) {
          let phase = "1. poluvrijeme";
          if (elapsedMs > FULLTIME_MS) phase = "Završeno";
          else if (elapsedMs > 60 * 60 * 1000) phase = "2. poluvrijeme";
          else if (elapsedMs > HALFTIME_MS) phase = "Pauza";

          countdownEl.innerHTML = `
            <div class="text-center">
              <span class="block text-2xl md:text-4xl font-display font-bold leading-tight text-club-accent">${phase}</span>
              <span class="text-xs md:text-sm uppercase tracking-widest text-white/60 mt-1 inline-block">${elapsedMin} min od početka</span>
            </div>
          `;
        }
        if (labelEl) labelEl.textContent = "Status utakmice";
        if (statusLabel) statusLabel.textContent = "Uživo";
        if (statusBadge) {
          statusBadge.classList.remove("bg-red-600");
          statusBadge.classList.add("bg-green-600");
        }
      }

      tick();
      setInterval(tick, 1000);
    }
  }
</script>
